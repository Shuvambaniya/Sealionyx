# Sealionyx Docker - Copy to .env and fill in your values
# cp .env.docker.example .env

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend crypto & auth (required)
CRYPTO_SECRET=your-fernet-key
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256

# Optional - Frontend API URL (default: http://localhost:8000)
# Use this when accessing the app at a different host/port
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional - Backend
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CA_COMMON_NAME=Sealionyx Root CA
CA_ORGANIZATION=Sealionyx
CA_COUNTRY=NP
CA_STATE=Kathmandu
CA_VALIDITY_DAYS=3650
USER_CERT_VALIDITY_DAYS=365
