# Sealionyx Backend Environment Variables
# Copy to .env and fill in your values

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cryptographic Secret for encrypting user private keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRYPTO_SECRET=your-fernet-key-here

# JWT Configuration (must match Supabase JWT secret)
JWT_SECRET=your-supabase-jwt-secret
JWT_ALGORITHM=HS256

# Server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CA Configuration
CA_COMMON_NAME=Sealionyx Root CA
CA_ORGANIZATION=Sealionyx
CA_COUNTRY=NP
CA_STATE=Kathmandu
CA_VALIDITY_DAYS=3650
USER_CERT_VALIDITY_DAYS=365
